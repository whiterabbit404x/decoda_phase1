# Development and Vercel environment examples.
# On Vercel Preview/Production, prefer API_URL so the same-origin auth proxy can use the server-side backend URL.
API_URL=https://your-api.example.com
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
# NEXT_PUBLIC_API_URL is only needed when the browser must call a public backend URL directly.
NEXT_PUBLIC_API_URL=https://your-api.example.com
NEXT_PUBLIC_API_TIMEOUT_MS=5000
NEXT_PUBLIC_LIVE_MODE_ENABLED=false
# Localhost fallback is disabled by default and must be explicitly opted into for local development only.
ALLOW_LOCAL_API_FALLBACK=false
